// Tide grammar — lexical part.
// Standard EBNF dialect (W3C-style):
//   *      zero or more
//   +      one or more
//   ?      optional
//   |      alternation
//   ( )    grouping
//   "..."  literal terminal
//   '...'  character class (shell-style)
//   //     comment to end of line
//
// Authority: this file is the contract. Prose mirror in
// ../docs/language-spec.md §Lexical may lag; on disagreement the
// EBNF wins. Every terminal here must be exercised by ≥ 1 fixture
// in ../tests/lexer/ (atomic-coverage rule, D17 — bootstrap-exempt
// for the formalization series).
//
// Reserved keywords and operators are listed in keywords.md; this
// file references them as quoted-string terminals.

// =============================================================
// Whitespace and comments
// =============================================================

Newline        = "\n" | "\r\n" ;
Whitespace     = ' ' | '\t' ;
LineComment    = "//" ('any character except newline')* ;
BlockComment   = "/*" ('any character')* "*/" ;
// Block comments are **not nested**. The `*/` that closes a
// `/*` is the **leftmost** occurrence after the `/*`; everything
// up to (and including) that `*/` is one comment. Code like
// `/* a /* b */ c */` consumes up to the first `*/`, leaving
// `c */` to be lexed normally — almost certainly a parse error.
SkipNonNewline = Whitespace | LineComment | BlockComment ;
// Newlines are significant tokens at statement-level, suppressed
// inside open brackets — see SyntaxNewlineSuppression in grammar
// (syntactic part).

// =============================================================
// Identifiers and keywords
// =============================================================

Letter      = 'a'..'z' | 'A'..'Z' | '_' ;        // ASCII only in v1
Digit       = '0'..'9' ;
HexDigit    = Digit | 'a'..'f' | 'A'..'F' ;
OctDigit    = '0'..'7' ;
BinDigit    = '0' | '1' ;

Ident       = Letter (Letter | Digit)* ;
// Identifiers are ASCII-only in v1. Allowing the full Unicode letter
// class (as Go does) is park material; the lexer never produces an
// Ident token from a non-ASCII first character.
//
// RESERVED PREFIX: an Ident whose first six characters are exactly
// `_tide_` (case-sensitive) is reserved for codegen-synthesised
// names and is REJECTED by the lexer with E0107 Reserved
// identifier prefix. This guarantees no collision with the
// `_tide_NN` fresh names introduced during desugaring; see
// `lowering-go.md` §Identifier encoding.

// Keyword is not a separate alternative in Token below — the lexer
// matches Ident first, then reclassifies the lexeme as a Keyword
// iff it appears in the reserved set. This avoids `intx` ambiguously
// starting to match the `int` family. The exhaustive Keyword set is
// listed here for the parser's reclassification table:
KeywordSet  = "import" | "type"   | "class"  | "interface"
            | "implements" | "extends" | "static"
            | "func"   | "let"    | "var"
            | "if"     | "else"
            | "for"    | "in"     | "while"  | "return"
            | "match"  | "try"    | "defer"
            | "spawn"  | "scope"  | "select"
            | "break"  | "continue"
            | "true"   | "false"  | "unit"
            | "this"
            ;

// =============================================================
// Integer literals
// =============================================================

DecimalLit  = Digit ( Digit | "_" )* ;
HexLit      = "0x" HexDigit ( HexDigit | "_" )* ;
OctalLit    = "0o" OctDigit ( OctDigit | "_" )* ;
BinaryLit   = "0b" BinDigit ( BinDigit | "_" )* ;
IntLit      = DecimalLit | HexLit | OctalLit | BinaryLit ;

// =============================================================
// Floating-point literals
// =============================================================

// FloatLit requires a digit on **both** sides of the dot — `1.0` is
// legal, bare `1.` and `.5` are not. Reason: without a trailing
// digit, `1..10` would lex as `FloatLit("1.") FloatLit(".10")`,
// breaking range literals. The mandatory-trailing-digit form
// resolves all such ambiguities without needing parser-time
// lookahead in the lexer. Hex / binary / octal *float* literals are
// not supported in v1 (no `0x1.8p3`-style forms).
FloatLit    = Digit+ "." Digit+ ExponentPart?
            | Digit+ ExponentPart
            ;
ExponentPart = ("e" | "E") ("+" | "-")? Digit+ ;

// =============================================================
// String and rune literals
// =============================================================

// Escape forms allowed in string and rune literals. Note the
// absence of Go's `\b`, `\f`, `\v`, `\a` (not in v1; reach for
// `\xNN` instead). No 8-digit `\U` form either — `\uNNNN` covers
// the BMP, which is enough for the v1 corpus.
EscapeChar  = "\\" ( "n" | "t" | "r" | "\\" | '"' | "'" | "0"
                  | "x" HexDigit HexDigit
                  | "u" HexDigit HexDigit HexDigit HexDigit ) ;

// String / rune literals may not contain a raw CR or LF —
// multi-line strings are not in v1.
StringChar  = EscapeChar | ('any char except "\\", "\"", CR, LF') ;
StringLit   = '"' StringChar* '"' ;

RuneChar    = EscapeChar | ('any char except "\\", "'", CR, LF') ;
RuneLit     = "'" RuneChar "'" ;

// =============================================================
// Operators
// =============================================================

// Listed longest-first; the lexer matches the longest sequence.
// Semantics in keywords.md §Operators.
Op = "..="        // inclusive range
   | "..."        // variadic (parameter / spread)
   | ".."         // half-open range
   | "=="         // equality
   | "!="         // inequality
   | "<="         // less or equal
   | ">="         // greater or equal
   | "&&"         // logical AND
   | "||"         // logical OR
   | "=>"         // arm separator (match / short closure)
   | "->"         // reserved for future use (not produced)
   | "<-"         // channel receive (only legal inside `select` case)
   | "+"  | "-"  | "*"  | "/"  | "%"
   | "="  | "!"
   | "<"  | ">"        // also generic brackets — see disambiguation
   | "|"               // variant separator and pattern alternative
   ;

// =============================================================
// Punctuation
// =============================================================

Punct = "(" | ")" | "[" | "]" | "{" | "}"
      | "."  | ","  | ";"  | ":"
      | "@"        // reserved for future use (annotations); the
                   // lexer recognises it as a token but no v1
                   // grammar production accepts it — the parser
                   // rejects with a diagnostic.
      ;

// =============================================================
// Token (top-level alternation)
// =============================================================

Token = Newline
      | Ident                      // reclassified to Keyword if lexeme ∈ KeywordSet
      | FloatLit                   // FloatLit before IntLit (dot disambiguation)
      | IntLit
      | StringLit
      | RuneLit
      | Op
      | Punct
      ;

// Whitespace and comments are skipped (not produced as tokens).
// Newline is produced as a Token; the parser later suppresses it
// inside open brackets per the syntactic part of this grammar.

// Reclassification: after matching an Ident-shape, the lexer looks
// up the lexeme in `KeywordSet`. On hit, the token's kind becomes
// `Keyword` (with the matched lexeme). On miss, the token stays
// `Ident`. This is the standard maximal-munch-then-reclassify
// algorithm; it avoids partial-keyword false starts like `intx`
// committing to `int`-the-keyword.

// =============================================================
// Lexical conflict resolution
// =============================================================
//
// 1. **Longest match.** Among all rules above, the lexer chooses the
//    longest match. This makes `..=` win over `..`, `==` over `=`,
//    `<-` over `<`, etc.
//
// 2. **Keyword vs Ident.** After matching an Ident-shape, the lexer
//    checks whether the text is in the Keyword set. If yes, it
//    produces a Keyword token; otherwise an Ident.
//
// 3. **FloatLit requires digits on both sides.** `1.0` is one
//    FloatLit; `1.` and `.5` are not. This removes every
//    `dot-after-digit` ambiguity at the lexical level:
//      - `1..10` lexes as `IntLit("1") Op("..") IntLit("10")` —
//        the longest-match rule picks `..` over `.`, and there is
//        no `FloatLit("1.")` to compete with.
//      - `1.foo()` lexes as `IntLit("1") Punct(".") Ident("foo")
//        Punct("(") Punct(")")` — same reasoning.
//      - Tuple-position access `t.0` lexes as `Ident("t")
//        Punct(".") IntLit("0")`.
//    Users who want `1.` write `1.0`; `.5` is `0.5`. The cost is
//    two characters; the gain is no parser-time lookback in the
//    lexer.
//
// 4. **Numeric `_` separator.** `1_000_000` is one IntLit; the `_`
//    characters are part of the literal and stripped at semantic
//    layer.
//
// 5. **Unary vs binary `-`.** The lexer emits a single `-` Op token
//    in both cases; the parser disambiguates by context.
//
// 6. **`<` and `>` as comparison vs generic brackets.** The lexer
//    always emits `<` / `>` as Op tokens. The parser resolves
//    generic-argument-list positions by lookahead — see
//    "Generic-argument disambiguation" in the syntactic section
//    below.


// =============================================================
// =============================================================
// SYNTACTIC GRAMMAR
// =============================================================
// =============================================================
//
// Every production names exactly one AST node kind (see
// `ast.md` — forthcoming). The grammar is presented in the
// order a recursive-descent parser would consume it.
//
// §SyntaxNewlineSuppression
// "Newline" below means the Newline token from the lexical
// part. Inside `(...)`, `[...]`, and `<...>` regions, Newline
// tokens are silently dropped before the parser sees them — this
// is the bracket-aware newline-suppression rule for argument
// lists, tuples, slice literals, and generic type-argument lists.
// **`{...}` blocks are NOT in the suppression set** — inside a
// block, Newline is the statement terminator; without it the
// parser cannot tell where one statement ends and the next
// begins. Inside record / map / set / stack literals (which also
// use `{ ... }`), Newline IS suppressed between entries — those
// productions list explicit `Newline?` markers where they are
// permitted. Outside any bracketed region, Newline is a statement
// terminator. Within a single statement, an explicit `;` may also
// terminate.

// =============================================================
// Top level
// =============================================================

File         = Newline* ( Import Stmtterm )* Decl ( Stmtterm Decl )* Newline* ;

Import       = "import" PackagePath ;
PackagePath  = Ident ( "/" Ident )* ;

Decl         = FuncDecl
             | TypeDecl
             | ClassDecl
             | InterfaceDecl
             | TopLevelLet
             ;

TopLevelLet  = "let" Ident ( ":" TypeExpr )? "=" Expr ;
                          // `var` is intentionally not legal at the
                          // top level — module-scope mutable state
                          // requires a class with a singleton
                          // instance (see language-spec.md §Records).

// =============================================================
// Type declarations
// =============================================================

TypeDecl     = "type" Ident TypeParams? "=" TypeBody ;
TypeBody     = RecordType
             | TupleTypeAlias
             | TypeExpr                    // simple alias
             | SumType
             ;

TypeParams   = "<" Ident ( "," Ident )* ">" ;

RecordType   = "{" Newline? FieldDecl ( FieldSep FieldDecl )* FieldSep? "}" ;
FieldDecl    = Ident ":" TypeExpr ;
FieldSep     = Newline+ | "," | "," Newline+ ;

TupleTypeAlias = "(" TypeExpr ( "," TypeExpr )+ ")" ;       // arity ≥ 2

SumType      = "|" Variant ( "|" Variant )+ ;               // arity ≥ 2
Variant      = Ident ( "(" Newline? FieldDecl ( "," Newline? FieldDecl )* ")" )? ;

// =============================================================
// Class and interface declarations
// =============================================================

ClassDecl    = "class" Ident TypeParams?
               ( "implements" InterfaceList )?
               "{" Newline? ClassMember* "}" ;
InterfaceList = TypeExpr ( "," TypeExpr )* ;

ClassMember  = ClassField
             | StaticMethod
             | InstanceMethod
             ;
ClassField   = ("let" | "var") Ident ":" TypeExpr Newline+ ;
StaticMethod = "static" Ident "(" ParamList? ")" ReturnAnnot? Block Newline* ;
InstanceMethod = Ident "(" ParamList? ")" ReturnAnnot? Block Newline* ;

InterfaceDecl = "interface" Ident TypeParams?
                ( "extends" InterfaceList )?
                "{" Newline? InterfaceMember* "}" ;
InterfaceMember = Ident "(" ParamList? ")" ReturnAnnot? Newline+ ;

// =============================================================
// Function declarations and shapes
// =============================================================

FuncDecl     = "func" Ident TypeParams? "(" ParamList? ")" ReturnAnnot? Block ;
ParamList    = Param ( "," Param )* ;
Param        = ( Ident | "_" ) ":" TypeExpr ;
ReturnAnnot  = ":" Newline? TypeExpr ;   // type may wrap to the next line

// =============================================================
// Type expressions
// =============================================================

TypeExpr     = PrimitiveType
             | NamedType
             | TupleType
             | SliceType
             | FuncType
             | InlineInterface
             ;

PrimitiveType = "bool" | "int" | "int8" | "int16" | "int32" | "int64"
              | "uint" | "uint8" | "uint16" | "uint32" | "uint64"
              | "float32" | "float64" | "byte" | "rune" | "string"
              | "unit"                              // value-type with one inhabitant `()`
              ;
// `Any`, `Dynamic`, and `error` are predeclared identifiers, not
// lexical primitives — they match `NamedType` (Ident lookup).
// Listed in `keywords.md`; type-system semantics in
// `type-system.md` (§Any landed; §Dynamic is the paired edit in
// PR-S3). `Dynamic` is the user-facing runtime-erased wrapper
// used by the reflection API per RFC-0003; `Any` is the
// binding-boundary FFI escape; the two are kept lexically distinct
// on purpose (see `keywords.md` §Built-in identifiers).
NamedType    = QualifiedIdent ( TypeArgs )? ;
QualifiedIdent = Ident ( "." Ident )* ;
TypeArgs     = "<" TypeExpr ( "," TypeExpr )* ">" ;
TupleType    = "(" TypeExpr ( "," TypeExpr )+ ")" ;
SliceType    = "[" "]" TypeExpr ;
FuncType     = "func" "(" ( TypeExpr ( "," TypeExpr )* )? ")" ReturnAnnot? ;
InlineInterface = "interface" "{" Newline? InterfaceMember* "}" ;

// =============================================================
// Statements
// =============================================================

Block        = "{" Newline? ( Stmt Stmtterm )* TrailingExpr? Newline? "}" ;
Stmt         = LetStmt
             | VarStmt
             | AssignStmt
             | IfStmt
             | ForStmt
             | WhileStmt
             | SelectStmt
             | DeferStmt
             | ExprStmt                      // wraps MatchExpr / ScopeExpr / CallExpr / ReturnExpr / BreakExpr / ContinueExpr / TryExpr etc.
             ;
TrailingExpr = Expr ;                        // last expression of a block — its value (no Stmtterm)

LetStmt      = ( "let" | "const" ) Pattern ( ":" TypeExpr )? "=" Expr ;
VarStmt      = "var" ( Ident | "_" ) ( ":" TypeExpr )? ( "=" Expr )? ;
AssignStmt   = LValue ( "=" | AssignOp ) Expr ;
AssignOp     = "+=" | "-=" | "*=" | "/=" | "%=" ;   // desugared by parser to `lhs = lhs <op> rhs`
LValue       = PostfixExpr ;                 // restricted by sema to writable shapes
IfStmt       = "if" Expr Block ( "else" ( IfStmt | Block ) )? ;
ForStmt      = "for" Pattern "in" Iterable Block ;
WhileStmt    = "while" Expr Block ;
SelectStmt   = "select" "{" Newline? ( SelectCase ( SelectCaseSep SelectCase )* SelectCaseSep? )? "}" ;
SelectCaseSep = "," Newline* | Newline+ ;
DeferStmt    = "defer" Expr ;
ExprStmt     = Expr ;

// `return` / `break` / `continue` are *diverging expressions* in
// PrimaryExpr (see DivergingExpr below); they appear at statement
// position as ExprStmt-wrapped DivergingExpr. Similarly `panic(msg)`
// and `os.exit(code)` are ordinary calls whose Never-typed result
// unifies with any expected type.

Iterable     = RangeExpr | Expr ;
RangeExpr    = AddExpr ( ".." | "..=" ) AddExpr ;
// RangeExpr is admitted only in `for ... in` headers and inside
// slice slicing (where its operands appear as `Expr? ":" Expr?` —
// the `..`/`..=` form is for-loop-only). General expressions cannot
// produce a range value in v1.

Stmtterm     = Newline+ | ";" Newline* ;

// =============================================================
// Expressions  —  precedence climbing
// =============================================================
// Precedence (low → high), all left-associative unless noted:
//
//   1   ||
//   2   &&
//   3   == != (non-associative)
//   4   < <= > >= (non-associative)
//   5   + -
//   6   * / %
//   7   prefix ! and unary -
//   8   postfix . [ ] [ : ] call < > generic-args
//   9   primary
//
// See operators.md (forthcoming — folded into keywords.md for v1)
// for the formal precedence table.

Expr         = OrExpr ;
OrExpr       = AndExpr ( "||" AndExpr )* ;
AndExpr      = EqExpr  ( "&&" EqExpr )* ;
EqExpr       = CmpExpr ( ( "==" | "!=" ) CmpExpr )? ;
CmpExpr      = AddExpr ( ( "<" | "<=" | ">" | ">=" ) AddExpr )? ;
AddExpr      = MulExpr ( ( "+" | "-" ) MulExpr )* ;
MulExpr      = UnaryExpr ( ( "*" | "/" | "%" ) UnaryExpr )* ;
UnaryExpr    = ( "!" | "-" )* PostfixExpr ;
PostfixExpr  = PrimaryExpr ( Newline? Suffix )* ;
             // Newline? before a Suffix is only honoured when the Suffix
             // begins with `.` (FieldSuffix / TupleFieldSuffix) — i.e.
             // leading-dot method-chain continuation (`xs⏎ .filter(p)⏎
             // .map(f)`). A newline before any other Suffix, and before
             // a binary operator, still terminates the expression:
             // unbracketed operator continuation is NOT adopted (an open
             // D11 question). Inside brackets all newlines are already
             // suppressed (§SyntaxNewlineSuppression).
Suffix       = CallSuffix
             | IndexSuffix
             | SliceSuffix
             | FieldSuffix
             | TupleFieldSuffix
             ;
CallSuffix       = TypeArgs? "(" ArgList? ")" ;
IndexSuffix      = "[" Expr "]" ;
SliceSuffix      = "[" Expr? ":" Expr? "]" ;          // half-open
FieldSuffix      = "." Ident ;
TupleFieldSuffix = "." IntLit ;
// Lexical note: a chained tuple index such as `r.1.0` lexes the `1.0`
// run as a single FloatLit (the lexer is context-free), not `.1` `.0`.
// The parser re-splits a `digits "." digits` FloatLit that follows a
// `.` suffix back into two TupleFieldSuffix indices. Any other float
// form (exponent, etc.) is not a tuple-index chain and stays an error.
ArgList          = Expr ( "," Newline? Expr )* ;

PrimaryExpr  = Literal
             | ThisExpr                              // explicit class receiver
             | ScopeRef                              // `scope` as a value, supports `.context` etc.
             | Ident
             | "(" Expr ")"
             | TupleLit
             | SliceLit
             | BraceLit                              // RecordLit / MapLit / SetLit / StackLit — disambiguated by content (see below)
             | Block                                 // block-as-expression
             | IfExpr
             | MatchExpr
             | ScopeExpr
             | TryExpr
             | SpawnExpr
             | ClosureLit
             | UnitLit
             | DivergingExpr                         // return / break / continue
             ;

Literal      = IntLit | FloatLit | StringLit | RuneLit | "true" | "false" ;
UnitLit      = "(" ")" ;
ThisExpr     = "this" ;                              // legal only inside instance-method bodies (sema check)

// `scope` used in expression position (not heading a ScopeExpr block).
// Disambiguation against ScopeExpr: the parser commits to ScopeExpr
// when the token *after* `scope` is `<` (TypeArgs), `(` (parent ctx),
// or `{` (body); otherwise it parses ScopeRef and lets subsequent
// suffix operators (typically `.context`) attach.
ScopeRef     = "scope" ;

DivergingExpr = ReturnExpr | BreakExpr | ContinueExpr ;
ReturnExpr   = "return" Expr? ;
BreakExpr    = "break" ;
ContinueExpr = "continue" ;

// `panic(...)` and `os.exit(...)` are diverging by virtue of their
// signatures (built-in / binding returns Never), not via dedicated
// productions — they parse as ordinary calls.

TupleLit     = "(" Expr ( "," Newline? Expr )+ ","? Newline? ")" ;     // arity ≥ 2
SliceLit     = "[" Newline? ( Expr ( "," Newline? Expr )* ","? Newline? )? "]"
             | SliceType "{" Newline? ( Expr ( "," Newline? Expr )* ","? Newline? )? "}"
             ;

// BraceLit covers RecordLit / MapLit / SetLit / StackLit — all share
// the `NamedType "{" ... "}"` prefix, so the production must accept
// any of the entry shapes and let the parser commit on the first
// entry.
BraceLit      = NamedType "{" Newline? BraceLitBody? "}" ;
BraceLitBody  = RecordEntry ( "," Newline? RecordEntry )* ","? Newline?
              | MapEntry    ( "," Newline? MapEntry    )* ","? Newline?
              | SetEntry    ( "," Newline? SetEntry    )* ","? Newline?
              ;
RecordEntry   = Ident ":" Expr ;                     // key is a bare Ident — record
MapEntry      = MapKey ":" Expr ;                    // key is non-Ident expression — map
MapKey        = StringLit | IntLit | RuneLit | "true" | "false"
              | "(" Expr ")"                         // parenthesised key for general expr
              ;
SetEntry      = Expr ;                               // no `:` after — set element

// Parser-side disambiguation: with the first entry's first token,
//   - `Ident ":"`                   → RecordEntry mode (continue with RecordEntry list).
//   - `MapKey ":"`                  → MapEntry mode.
//   - Anything else followed by `,`/`}` → SetEntry mode.
//   - Empty `{}`                    → ambiguous at parse; type info from NamedType decides
//                                       (RecordLit if all fields are `Option<_>`, StackLit
//                                       for Stack<T>, empty Map / Set / etc. otherwise).

ClosureLit   = "func" "(" ParamList? ")" ReturnAnnot? Block
             | "(" ShortParamList? ")" "=>" Expr        // short closure — type annotations optional
             ;
ShortParamList = ShortParam ( "," ShortParam )* ;
ShortParam     = ( Ident | "_" ) ( ":" TypeExpr )? ;

IfExpr       = "if" Expr Block "else" ( IfExpr | Block ) ;   // both arms required for value
MatchExpr    = "match" Expr "{" Newline? MatchArm ( "," Newline? MatchArm )* ","? Newline? "}" ;
MatchArm     = Pattern "=>" Newline? ( Expr | AssignStmt ) ;
             // Newline?: body may wrap to next line. Expr covers inline expressions,
             // Blocks (via PrimaryExpr→Block), and divergences (return/break/continue)
             // via DivergingExpr. A braceless AssignStmt (`Some(h) => h.prev = x`) is a
             // side-effecting arm body, wrapped by the parser in an implicit unit Block.

ScopeExpr    = "scope" TypeArgs? ( "(" Expr ")" )? Block ;   // optional parent ctx
TryExpr      = "try" Expr ;
SpawnExpr    = "spawn" Block ;

// =============================================================
// Patterns
// =============================================================

Pattern      = AltPat                                // try alternatives first; falls through to single-pat
             | SinglePat
             ;
SinglePat    = WildcardPat
             | LiteralPat
             | UnitPat
             | VariantPat                            // VariantPat before IdentPat — nullary `Some`/`None`/`Up`
                                                     //   match here, not as a fresh identifier binding.
                                                     //   The resolver decides "known variant" vs "new
                                                     //   binding" at sema time, but at grammar level
                                                     //   we commit to VariantPat when the head
                                                     //   QualifiedIdent's first component is a known
                                                     //   variant-name; otherwise IdentPat.
             | IdentPat
             | TuplePat
             | RecordPat
             ;
WildcardPat  = "_" ;
LiteralPat   = IntLit | StringLit | RuneLit | "true" | "false" ;
UnitPat      = "(" ")" ;
IdentPat     = Ident ;                               // binding
TuplePat     = "(" Pattern ( "," Pattern )+ ","? ")" ;
VariantPat   = QualifiedIdent ( "(" Pattern ( "," Pattern )* ","? ")" )? ;
RecordPat    = NamedType "{" Newline? RecordPatField ( "," Newline? RecordPatField )* ","? Newline? "}" ;
RecordPatField = Ident ":" Pattern ;

// Alternatives — literal patterns OR nullary variants (corpus uses
// both: `'(' | '[' | '{'` in valid_parentheses.td and
// `Up | Left` in p1033.td). Mixing literal and variant in one
// AltPat is legal at the grammar level; sema enforces the union
// makes sense.
AltPat       = AltAtom ( "|" AltAtom )+ ;
AltAtom      = LiteralPat | VariantPat ;

// =============================================================
// Select cases (only inside SelectStmt)
// =============================================================

SelectCase   = SelectRecv | SelectSend | SelectDefault ;
SelectRecv   = "case" ( Ident "=" )? "<-" Expr "=>" Block ;
// `send` is recognised as a method-call shape (PostfixExpr ending in
// CallSuffix). The parser parses the case head as a PostfixExpr and
// enforces that it is exactly `Expr "." "send" "(" Expr ")"` — a
// single-argument method call on a channel — rejecting any other
// shape with E0112 at parse time (the head is also where `Ident "="
// "<-"` recv-binds are disambiguated, so one site owns the check).
SelectSend   = "case" PostfixExpr "=>" Block ;
SelectDefault = "default" "=>" Block ;

// =============================================================
// Generic-argument disambiguation (resolves `<` from comparison)
// =============================================================
//
// At a position where a PostfixExpr suffix could be either
// `< Expr (comparison)` or `< TypeArgs > ( ... )` (a generic
// call), the parser uses one-token lookahead **plus** structural
// validation:
//
//   1. Speculatively parse `< TypeExpr ( "," TypeExpr )* >`.
//   2. If the next token after the speculative `>` is one of:
//        `(`   — function call (e.g. `f<int>(x)`)
//        `{`   — generic literal (e.g. `Set<int>{ 1, 2 }`,
//                `Envelope<HelloPayload>{ ... }`)
//        `.`   — generic static-method call
//                (`LRU<string, int>.new(2)`,
//                `Broker<int>.new()`)
//      commit to TypeArgs.
//   3. Otherwise, rewind and treat the `<` as comparison.
//
// This is the same rule Go uses for the analogous case in its
// `expr.IndexExpr` disambiguation. It is local — a single
// lookahead — and has no exponential blow-up: speculative parse
// fails fast on first non-TypeExpr token.
